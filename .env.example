# ========== 必填 ==========
DISCORD_TOKEN=your_discord_bot_token

OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key
OPENAI_MODEL_NAME=gpt-4o

# ========== 可选：网络代理（国内或受限网络建议配置）==========
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ========== 可选：彩虹屁 ==========
COMPLIMENT_ENABLED=true
COMPLIMENT_PROBABILITY=0.3
COMPLIMENT_COOLDOWN=60
COMPLIMENT_MODE=lite

# ========== 可选：随机聊天 ==========
CHAT_ENABLED=false
CHAT_PROBABILITY=0.15
CHAT_HISTORY_LIMIT=8

# ========== 可选：欢迎消息频道（Discord 频道 ID）==========
WELCOME_CHANNEL_ID=1442454462730993697

# ========== 可选：Web 服务端口（Docker / Railway / Render 等平台）==========
PORT=7860

# ========== 可选：Danbooru 浏览面板 ==========
DANBOORU_API_BASE=https://danbooru.donmai.us
# DANBOORU_API_USER=
# DANBOORU_API_KEY=
DANBOORU_TAGS_PER_PAGE=15
DANBOORU_CACHE_TTL=3600
# 首次见到的 tag 用 AI 汉化并写入 tag_cn_cache.json（无需手维护对照表）
TAG_TRANSLATE_AI=true
# TAG_CN_CACHE_FILE=tag_cn_cache.json
